<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f2f5; color: #111; min-height: 100vh; }

    /* ── Header ── */
    header { background: #128C7E; color: #fff; padding: 12px 18px; display: flex; align-items: center; gap: 10px; position: sticky; top: 0; z-index: 20; box-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: -.3px; }
    .logo span { color: #a5d6a7; }
    header .spacer { flex: 1; }
    header form button { background: rgba(255,255,255,.15); border: none; color: #fff; font-size: .78rem; padding: 5px 12px; border-radius: 6px; cursor: pointer; }
    header form button:hover { background: rgba(255,255,255,.25); }

    /* ── Nav ── */
    nav { background: #0f7268; display: flex; overflow-x: auto; scrollbar-width: none; }
    nav::-webkit-scrollbar { display: none; }
    nav a { color: rgba(255,255,255,.7); text-decoration: none; padding: 10px 18px; font-size: .82rem; font-weight: 500; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .15s, border-color .15s; }
    nav a:hover { color: #fff; }
    nav a.active { color: #fff; border-bottom-color: #25D366; }

    /* ── Layout ── */
    main { max-width: 700px; margin: 0 auto; padding: 18px 12px 40px; }

    /* ── Stats ── */
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 9px; margin-bottom: 18px; }
    .stat-card { background: #fff; border-radius: 10px; padding: 13px 15px; box-shadow: 0 1px 3px rgba(0,0,0,.07); }
    .stat-label { font-size: .68rem; color: #999; text-transform: uppercase; letter-spacing: .4px; }
    .stat-value { font-size: 1.55rem; font-weight: 700; margin-top: 3px; }
    .stat-card.alert .stat-value { color: #e53935; }

    /* ── Search ── */
    .search-wrap { position: relative; margin-bottom: 12px; }
    .search-wrap svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: #bbb; pointer-events: none; }
    #search { width: 100%; padding: 9px 12px 9px 36px; border: 1.5px solid #e0e0e0; border-radius: 8px; font-size: .88rem; background: #fff; outline: none; transition: border-color .15s; }
    #search:focus { border-color: #25D366; }

    /* ── Section label ── */
    .section-label { font-size: .72rem; font-weight: 600; color: #bbb; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }

    /* ── Chat list ── */
    .chat-list { display: flex; flex-direction: column; gap: 6px; }
    .chat-card { background: #fff; border-radius: 10px; padding: 12px 14px; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit; box-shadow: 0 1px 2px rgba(0,0,0,.07); transition: box-shadow .15s, transform .1s; border-left: 3px solid transparent; }
    .chat-card:hover { box-shadow: 0 3px 10px rgba(0,0,0,.11); transform: translateY(-1px); }
    .chat-card-wrap { position: relative; }
    .hide-btn {
      position: absolute; top: 50%; right: 10px; transform: translateY(-50%);
      background: rgba(255,255,255,.92); border: 1px solid #e0e0e0; border-radius: 4px;
      width: 22px; height: 22px; font-size: .85rem; line-height: 1; cursor: pointer;
      color: #bbb; opacity: 0; transition: opacity .2s, color .15s;
      display: flex; align-items: center; justify-content: center;
    }
    .chat-card-wrap:hover .hide-btn { opacity: 1; }
    .hide-btn:hover { color: #e53935; border-color: #ef9a9a; }
    .chat-card.sin-resp { border-left-color: #e53935; }
    .avatar { width: 43px; height: 43px; border-radius: 50%; background: #128C7E; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; font-weight: 700; flex-shrink: 0; }
    .chat-info { flex: 1; min-width: 0; }
    .chat-name-row { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
    .chat-name { font-weight: 600; font-size: .92rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .badge { font-size: .62rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; white-space: nowrap; flex-shrink: 0; }
    .badge-hoy      { background: #e8f5e9; color: #2e7d32; }
    .badge-sinr     { background: #ffebee; color: #c62828; }
    .badge-proceso  { background: #fff3e0; color: #e65100; }
    .badge-resuelto { background: #e8f5e9; color: #1b5e20; }
    .chat-preview { font-size: .8rem; color: #888; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 3px; }
    .chat-preview.out::before { content: '✓ '; color: #25D366; }
    .chat-summary { font-size: .75rem; color: #5c8bc4; margin-top: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-style: italic; }
    .resumir-card-btn {
      margin-top: 5px; background: none; border: 1px solid #c5daf5; border-radius: 5px;
      color: #5c8bc4; font-size: .7rem; padding: 2px 8px; cursor: pointer; line-height: 1.6;
    }
    .resumir-card-btn:hover { background: #e8f4fd; }
    .resumir-card-btn:disabled { opacity: .55; cursor: default; }
    .chat-meta { text-align: right; flex-shrink: 0; }
    .chat-time { font-size: .72rem; color: #bbb; }
    .chat-count { display: inline-block; margin-top: 5px; background: #25D366; color: #fff; border-radius: 10px; font-size: .68rem; padding: 1px 8px; font-weight: 600; }

    .empty { text-align: center; color: #bbb; margin-top: 50px; font-size: .92rem; line-height: 1.7; }
    #no-results { display: none; text-align: center; color: #bbb; padding: 28px 0; font-size: .88rem; }

    @media (max-width: 480px) {
      .stats { gap: 7px; }
      .stat-value { font-size: 1.3rem; }
      .chat-card { padding: 11px 12px; }
      .avatar { width: 38px; height: 38px; }
    }

    /* ── Modal limpiar DB ── */
    .modal-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 100;
      background: rgba(0,0,0,.55);
      align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: #fff; border-radius: 12px; padding: 28px 24px;
      max-width: 360px; width: calc(100% - 32px);
      box-shadow: 0 8px 32px rgba(0,0,0,.22);
    }
    .modal-icon { font-size: 2rem; text-align: center; margin-bottom: 10px; }
    .modal-title { font-size: 1rem; font-weight: 700; color: #b71c1c; text-align: center; margin-bottom: 8px; }
    .modal-desc { font-size: .82rem; color: #555; line-height: 1.55; text-align: center; margin-bottom: 18px; }
    .modal-desc strong { color: #b71c1c; }
    .modal-input {
      width: 100%; padding: 9px 12px; border: 2px solid #e0e0e0; border-radius: 8px;
      font-size: .9rem; text-align: center; letter-spacing: .08em; outline: none;
      transition: border-color .15s; margin-bottom: 16px;
    }
    .modal-input:focus { border-color: #e53935; }
    .modal-actions { display: flex; gap: 10px; }
    .modal-cancel {
      flex: 1; padding: 9px; border: 1.5px solid #e0e0e0; border-radius: 8px;
      background: #fff; font-size: .85rem; font-weight: 600; color: #777; cursor: pointer;
    }
    .modal-cancel:hover { background: #f5f5f5; }
    .modal-confirm {
      flex: 1; padding: 9px; border: none; border-radius: 8px;
      background: #e53935; font-size: .85rem; font-weight: 600; color: #fff; cursor: pointer;
      transition: background .15s, opacity .15s;
    }
    .modal-confirm:disabled { opacity: .38; cursor: not-allowed; }
    .modal-confirm:not(:disabled):hover { background: #b71c1c; }
  </style>
</head>
<body>
  <header>
    <div class="logo">Wasap<span>Panel</span></div>
    <div class="spacer"></div>
    <% if (isAdmin) { %>
      <button onclick="abrirModalLimpiar()" style="background:rgba(229,57,53,.35);border:none;color:#fff;font-size:.78rem;padding:5px 12px;border-radius:6px;cursor:pointer;margin-right:4px;" title="Solo admin">🗑 Limpiar BD</button>
    <% } %>
    <form method="POST" action="/logout"><button type="submit">Salir</button></form>
  </header>
  <nav>
    <a href="/" class="active">Chats</a>
    <a href="/pendientes">Pendientes <% if(stats.sinRespuesta > 0){ %><span style="background:#e53935;color:#fff;border-radius:10px;padding:1px 6px;font-size:.65rem;margin-left:2px;"><%= stats.sinRespuesta %></span><% } %></a>
    <a href="/contactos">Contactos</a>
    <a href="/estadisticas">Estadísticas</a>
    <a href="/buscar">Buscar</a>
    <% if (isAdmin) { %><a href="/ocultos">Ocultos</a><% } %>
  </nav>

  <main>
    <div class="stats">
      <div class="stat-card">
        <div class="stat-label">Mensajes hoy</div>
        <div class="stat-value"><%= stats.msgsToday %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Chats activos hoy</div>
        <div class="stat-value"><%= stats.chatsToday %></div>
      </div>
      <div class="stat-card <%= stats.sinRespuesta > 0 ? 'alert' : '' %>">
        <div class="stat-label">Sin respuesta</div>
        <div class="stat-value"><%= stats.sinRespuesta %></div>
      </div>
    </div>

    <% if (chats.length === 0) { %>
      <p class="empty">Ningún chat registrado todavía.<br>Instalá la extensión y abrí un chat en WhatsApp Web.</p>
    <% } else { %>

      <div class="search-wrap">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="search" placeholder="Filtrar por nombre o número…" autocomplete="off">
      </div>

<div class="section-label" id="section-label"><%= chats.length %> conversacion<%= chats.length !== 1 ? 'es' : '' %></div>

      <div class="chat-list" id="chat-list">
        <% chats.forEach(function(chat) {
          const initial = (chat.phone_or_name || '?')[0].toUpperCase();
          const d       = new Date(chat.last_message_ts || chat.last_seen);
          const today   = new Date();
          const isToday = d.toDateString() === today.toDateString();
          const sinResp = chat.last_direction === 'in';
          let timeLabel;
          if (isToday) {
            timeLabel = d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit', hour12: false });
          } else {
            const yest = new Date(today); yest.setDate(today.getDate() - 1);
            timeLabel = d.toDateString() === yest.toDateString()
              ? 'Ayer'
              : d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit' });
          }
        %>
          <div class="chat-card-wrap"
               data-name="<%= chat.phone_or_name.toLowerCase() %>">
            <a class="chat-card <%= sinResp && isToday ? 'sin-resp' : '' %>"
               href="/chat/<%= chat.id %>">
              <div class="avatar"><%= initial %></div>
              <div class="chat-info">
                <div class="chat-name-row">
                  <div class="chat-name"><%= chat.phone_or_name %></div>
                  <% if (isToday)  { %><span class="badge badge-hoy">HOY</span><% } %>
                  <% if (sinResp && isToday) { %><span class="badge badge-sinr">SIN RESP</span><% } %>
                  <% if (chat.status === 'en_proceso') { %><span class="badge badge-proceso">En proceso</span><% } %>
                  <% if (chat.status === 'resuelto')   { %><span class="badge badge-resuelto">✓ Resuelto</span><% } %>
                </div>
                <div class="chat-preview <%= chat.last_direction === 'out' ? 'out' : '' %>"><%= chat.last_message || '—' %></div>
                <% if (chat.ai_summary) { %>
                  <div class="chat-summary" id="summary-<%= chat.id %>">🤖 <%= chat.ai_summary %></div>
                <% } else { %>
                  <button class="resumir-card-btn" id="summary-btn-<%= chat.id %>"
                          onclick="resumirCard(event, <%= chat.id %>)">🤖 Resumir sesión</button>
                <% } %>
              </div>
              <div class="chat-meta">
                <div class="chat-time"><%= timeLabel %></div>
                <div class="chat-count"><%= chat.message_count %></div>
              </div>
            </a>
            <button class="hide-btn" data-id="<%= chat.id %>" onclick="ocultarChat(event, this)" title="Ocultar conversación">×</button>
          </div>
        <% }); %>
      </div>
      <div id="no-results">No se encontraron chats.</div>

    <% } %>
  </main>

  <script>
    // Filtro por nombre (cliente)
    const search   = document.getElementById('search');
    const list     = document.getElementById('chat-list');
    const noRes    = document.getElementById('no-results');
    const secLabel = document.getElementById('section-label');

    function applyFilters() {
      if (!list) return;
      const q     = (search ? search.value.toLowerCase().trim() : '');
      const cards = list.querySelectorAll('.chat-card-wrap');
      let vis     = 0;
      cards.forEach(card => {
        const show = !q || card.dataset.name.includes(q);
        card.style.display = show ? '' : 'none';
        if (show) vis++;
      });
      if (noRes) noRes.style.display = vis === 0 ? 'block' : 'none';
      if (secLabel) secLabel.textContent = vis + ' conversacion' + (vis !== 1 ? 'es' : '');
    }

    if (search) search.addEventListener('input', applyFilters);

    function ocultarChat(e, btn) {
      e.stopPropagation();
      const wrap = btn.closest('.chat-card-wrap');
      fetch('/chat/' + btn.dataset.id + '/hide', { method: 'POST' })
        .then(r => r.json())
        .then(d => {
          if (d.ok) {
            wrap.style.transition = 'opacity .25s';
            wrap.style.opacity = '0';
            setTimeout(() => wrap.remove(), 260);
          }
        })
        .catch(() => {});
    }

    async function resumirCard(e, id) {
      e.preventDefault();
      e.stopPropagation();
      const btn = document.getElementById('summary-btn-' + id);
      if (!btn) return;
      btn.textContent = '⏳ Analizando…';
      btn.disabled = true;
      try {
        const r = await fetch('/chat/' + id + '/summarize', { method: 'POST' });
        const d = await r.json();
        if (d.ok) {
          const el = document.createElement('div');
          el.className = 'chat-summary';
          el.id = 'summary-' + id;
          el.textContent = '🤖 ' + d.summary;
          btn.replaceWith(el);
        } else {
          btn.textContent = '🤖 Resumir sesión';
          btn.disabled = false;
        }
      } catch (_) {
        btn.textContent = '🤖 Resumir sesión';
        btn.disabled = false;
      }
    }

    // Auto-refresh cada 30 s, solo si el usuario no está filtrando
    setInterval(() => {
      if (!search || !search.value.trim()) location.reload();
    }, 30000);
  </script>

  <% if (isAdmin) { %>
  <div class="modal-overlay" id="modal-limpiar">
    <div class="modal-box">
      <div class="modal-icon">⚠️</div>
      <div class="modal-title">Limpiar base de datos</div>
      <div class="modal-desc">
        Esta acción borrará <strong>todos los chats y mensajes</strong> de forma permanente.<br>
        No se puede deshacer.<br><br>
        Escribí <strong>BORRAR</strong> para confirmar.
      </div>
      <input class="modal-input" id="confirm-input" type="text" placeholder="BORRAR" autocomplete="off" oninput="checkConfirm()">
      <div class="modal-actions">
        <button class="modal-cancel" onclick="cerrarModalLimpiar()">Cancelar</button>
        <button class="modal-confirm" id="confirm-btn" disabled onclick="ejecutarLimpiar()">Confirmar</button>
      </div>
    </div>
  </div>

  <script>
    function abrirModalLimpiar() {
      document.getElementById('confirm-input').value = '';
      document.getElementById('confirm-btn').disabled = true;
      document.getElementById('modal-limpiar').classList.add('open');
      setTimeout(() => document.getElementById('confirm-input').focus(), 80);
    }
    function cerrarModalLimpiar() {
      document.getElementById('modal-limpiar').classList.remove('open');
    }
    function checkConfirm() {
      const val = document.getElementById('confirm-input').value.trim();
      document.getElementById('confirm-btn').disabled = val !== 'BORRAR';
    }
    async function ejecutarLimpiar() {
      const btn = document.getElementById('confirm-btn');
      btn.textContent = 'Borrando…';
      btn.disabled = true;
      try {
        const r = await fetch('/admin/clear-db', { method: 'POST' });
        const d = await r.json();
        if (d.ok) {
          location.reload();
        } else {
          alert('Error: ' + (d.error || 'desconocido'));
          cerrarModalLimpiar();
        }
      } catch (_) {
        alert('Error de red.');
        cerrarModalLimpiar();
      }
    }
    document.getElementById('modal-limpiar').addEventListener('click', function(e) {
      if (e.target === this) cerrarModalLimpiar();
    });
  </script>
  <% } %>
</body>
</html>
