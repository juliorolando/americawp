<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contactos — WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f2f5; color: #111; min-height: 100vh; }

    header { background: #128C7E; color: #fff; padding: 12px 18px; display: flex; align-items: center; gap: 10px; position: sticky; top: 0; z-index: 20; box-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: -.3px; }
    .logo span { color: #a5d6a7; }
    header .spacer { flex: 1; }
    header form button { background: rgba(255,255,255,.15); border: none; color: #fff; font-size: .78rem; padding: 5px 12px; border-radius: 6px; cursor: pointer; }
    header form button:hover { background: rgba(255,255,255,.25); }

    nav { background: #0f7268; display: flex; overflow-x: auto; scrollbar-width: none; }
    nav::-webkit-scrollbar { display: none; }
    nav a { color: rgba(255,255,255,.7); text-decoration: none; padding: 10px 18px; font-size: .82rem; font-weight: 500; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .15s; }
    nav a:hover { color: #fff; }
    nav a.active { color: #fff; border-bottom-color: #25D366; }

    main { max-width: 700px; margin: 0 auto; padding: 18px 12px 40px; }

    /* ── Search ── */
    .search-wrap { position: relative; margin-bottom: 12px; }
    .search-wrap svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: #bbb; pointer-events: none; }
    #search { width: 100%; padding: 9px 12px 9px 36px; border: 1.5px solid #e0e0e0; border-radius: 8px; font-size: .88rem; background: #fff; outline: none; transition: border-color .15s; }
    #search:focus { border-color: #25D366; }

    .section-label { font-size: .72rem; font-weight: 600; color: #bbb; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
    #no-results { display: none; text-align: center; color: #bbb; padding: 28px 0; font-size: .88rem; }

    /* ── Contact card ── */
    .contact-card {
      background: #fff;
      border-radius: 10px;
      padding: 13px 15px;
      display: flex;
      align-items: center;
      gap: 13px;
      box-shadow: 0 1px 2px rgba(0,0,0,.07);
      margin-bottom: 6px;
      transition: box-shadow .15s, transform .1s;
    }
    .contact-card:hover { box-shadow: 0 3px 10px rgba(0,0,0,.1); transform: translateY(-1px); }

    .avatar {
      width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; font-weight: 700; color: #fff;
    }

    .contact-info { flex: 1; min-width: 0; }
    .contact-name { font-weight: 600; font-size: .92rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px; }
    .contact-meta { font-size: .73rem; color: #aaa; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .msg-count { background: #f0f2f5; color: #666; border-radius: 10px; padding: 1px 7px; font-size: .68rem; font-weight: 600; }

    .contact-actions { display: flex; gap: 6px; flex-shrink: 0; align-items: center; }

    .act-btn {
      border-radius: 6px; padding: 6px 11px; font-size: .74rem; font-weight: 600;
      cursor: pointer; text-decoration: none; white-space: nowrap; border: 1.5px solid;
      transition: all .15s; display: inline-flex; align-items: center; gap: 5px;
      line-height: 1;
    }
    .btn-copy  { background: #f5f5f5; color: #666;    border-color: #e0e0e0; }
    .btn-copy:hover { background: #ebebeb; }
    .btn-copy.copiado { background: #e8f5e9; color: #2e7d32; border-color: #a5d6a7; }
    .btn-wa   { background: #e8f5e9; color: #1b5e20; border-color: #a5d6a7; }
    .btn-wa:hover { background: #c8e6c9; }
    .btn-ver  { background: #fff; color: #128C7E; border-color: #b2dfdb; }
    .btn-ver:hover { background: #e0f2f1; }

    .empty { text-align: center; color: #bbb; margin-top: 60px; font-size: .92rem; line-height: 1.7; }

    @media (max-width: 500px) {
      .btn-ver { display: none; }
      .contact-card { padding: 11px 12px; gap: 10px; }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">Wasap<span>Panel</span></div>
    <div class="spacer"></div>
    <form method="POST" action="/logout"><button>Salir</button></form>
  </header>
  <nav>
    <a href="/">Chats</a>
    <a href="/pendientes">Pendientes</a>
    <a href="/contactos" class="active">Contactos</a>
    <a href="/estadisticas">Estadísticas</a>
    <a href="/buscar">Buscar</a>
    <a href="/ocultos">Ocultos</a>
  </nav>

  <main>
    <%
      const PALETTE = ['#128C7E','#0288D1','#7B1FA2','#C62828','#E65100','#2E7D32','#00838F','#558B2F','#6A1B9A','#AD1457'];
      function avatarColor(name) {
        let h = 0;
        for (let i = 0; i < (name || '').length; i++) h = (name.charCodeAt(i) + ((h << 5) - h)) | 0;
        return PALETTE[Math.abs(h) % PALETTE.length];
      }
      function formatDate(ts) {
        if (!ts) return null;
        const d = new Date(ts), today = new Date();
        if (d.toDateString() === today.toDateString())
          return 'Hoy ' + d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit', hour12: false });
        const yest = new Date(today); yest.setDate(today.getDate() - 1);
        if (d.toDateString() === yest.toDateString()) return 'Ayer';
        return d.toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: '2-digit' });
      }
    %>

    <% if (contacts.length === 0) { %>
      <p class="empty">No hay contactos registrados aún.</p>
    <% } else { %>

      <div class="search-wrap">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="search" placeholder="Buscar contacto…" autocomplete="off">
      </div>

      <div class="section-label" id="section-label"><%= contacts.length %> contacto<%= contacts.length !== 1 ? 's' : '' %></div>

      <div id="contact-list">
        <% contacts.forEach(function(c) {
          const digits  = (c.phone_or_name || '').replace(/\D/g, '');
          const waUrl   = digits.length >= 7 ? 'https://wa.me/' + digits : null;
          const initial = (c.phone_or_name || '?')[0].toUpperCase();
          const dateStr = formatDate(c.last_message_ts);
        %>
          <div class="contact-card" data-name="<%= c.phone_or_name.toLowerCase() %>">

            <div class="avatar" style="background:<%= avatarColor(c.phone_or_name) %>"><%= initial %></div>

            <div class="contact-info">
              <div class="contact-name"><%= c.phone_or_name %></div>
              <div class="contact-meta">
                <span class="msg-count"><%= c.message_count %> msg</span>
                <% if (dateStr) { %><span><%= dateStr %></span><% } %>
              </div>
            </div>

            <div class="contact-actions">
              <button class="act-btn btn-copy"
                      data-text="<%= c.phone_or_name %>"
                      onclick="copiar(this)"
                      title="Copiar número">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                Copiar
              </button>

              <% if (waUrl) { %>
                <a class="act-btn btn-wa" href="<%= waUrl %>" target="_blank" rel="noopener" title="Abrir en WhatsApp Web">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                  Enviar
                </a>
              <% } %>

              <a class="act-btn btn-ver" href="/chat/<%= c.id %>">Ver chat</a>
            </div>

          </div>
        <% }); %>
      </div>
      <div id="no-results">No se encontraron contactos.</div>

    <% } %>
  </main>

  <script>
    const search   = document.getElementById('search');
    const list     = document.getElementById('contact-list');
    const noRes    = document.getElementById('no-results');
    const secLabel = document.getElementById('section-label');

    if (search) {
      search.addEventListener('input', () => {
        const q     = search.value.toLowerCase().trim();
        const cards = list ? list.querySelectorAll('.contact-card') : [];
        let vis = 0;
        cards.forEach(card => {
          const show = !q || card.dataset.name.includes(q);
          card.style.display = show ? '' : 'none';
          if (show) vis++;
        });
        if (noRes)    noRes.style.display    = vis === 0 ? 'block' : 'none';
        if (secLabel) secLabel.textContent   = vis + ' contacto' + (vis !== 1 ? 's' : '');
      });
    }

    function copiar(btn) {
      const text = btn.dataset.text;
      const ICON_COPY = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copiar';
      const ICON_OK   = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copiado';

      const doFeedback = () => {
        btn.classList.add('copiado');
        btn.innerHTML = ICON_OK;
        setTimeout(() => { btn.classList.remove('copiado'); btn.innerHTML = ICON_COPY; }, 2000);
      };

      if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(doFeedback).catch(() => fallback(text, doFeedback));
      } else {
        fallback(text, doFeedback);
      }
    }

    function fallback(text, cb) {
      const el = document.createElement('textarea');
      el.value = text;
      el.style.position = 'fixed'; el.style.opacity = '0';
      document.body.appendChild(el);
      el.focus(); el.select();
      try { document.execCommand('copy'); cb(); } catch (_) {}
      document.body.removeChild(el);
    }
  </script>
</body>
</html>
