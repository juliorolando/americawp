<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pendientes — WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f2f5; color: #111; min-height: 100vh; }

    header { background: #128C7E; color: #fff; padding: 12px 18px; display: flex; align-items: center; gap: 10px; position: sticky; top: 0; z-index: 20; box-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: -.3px; }
    .logo span { color: #a5d6a7; }
    header .spacer { flex: 1; }
    header form button { background: rgba(255,255,255,.15); border: none; color: #fff; font-size: .78rem; padding: 5px 12px; border-radius: 6px; cursor: pointer; }
    header form button:hover { background: rgba(255,255,255,.25); }

    nav { background: #0f7268; display: flex; overflow-x: auto; scrollbar-width: none; }
    nav::-webkit-scrollbar { display: none; }
    nav a { color: rgba(255,255,255,.7); text-decoration: none; padding: 10px 18px; font-size: .82rem; font-weight: 500; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .15s; }
    nav a:hover { color: #fff; }
    nav a.active { color: #fff; border-bottom-color: #25D366; }

    main { max-width: 700px; margin: 0 auto; padding: 20px 12px 40px; }

    .page-title { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
    .page-sub   { font-size: .82rem; color: #888; margin-bottom: 18px; }

    .pending-card {
      background: #fff;
      border-radius: 10px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      text-decoration: none;
      color: inherit;
      box-shadow: 0 1px 2px rgba(0,0,0,.07);
      border-left: 4px solid #e53935;
      margin-bottom: 8px;
      transition: box-shadow .15s, transform .1s;
    }
    .pending-card:hover { box-shadow: 0 3px 10px rgba(0,0,0,.11); transform: translateY(-1px); }

    .pending-wrap { position: relative; margin-bottom: 8px; }
    .resolver-btn {
      position: absolute; top: 50%; right: 12px; transform: translateY(-50%);
      background: #e8f5e9; color: #2e7d32; border: 1.5px solid #a5d6a7;
      border-radius: 6px; padding: 5px 12px; font-size: .74rem; font-weight: 600;
      cursor: pointer; white-space: nowrap; opacity: 0; transition: opacity .2s;
    }
    .pending-wrap:hover .resolver-btn { opacity: 1; }
    .resolver-btn:hover { background: #c8e6c9; }

    .avatar { width: 43px; height: 43px; border-radius: 50%; background: #e53935; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; font-weight: 700; flex-shrink: 0; }

    .card-info { flex: 1; min-width: 0; }
    .card-name  { font-weight: 600; font-size: .93rem; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-msg   { font-size: .81rem; color: #555; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .card-meta  { text-align: right; flex-shrink: 0; }
    .wait-time  { font-size: .8rem; font-weight: 700; color: #e53935; }
    .wait-label { font-size: .68rem; color: #bbb; margin-top: 2px; }

    .empty { text-align: center; color: #bbb; margin-top: 60px; font-size: .92rem; line-height: 1.7; }
    .empty .icon { font-size: 2.5rem; margin-bottom: 10px; }
  </style>
</head>
<body>
  <header>
    <div class="logo">Wasap<span>Panel</span></div>
    <div class="spacer"></div>
    <form method="POST" action="/logout"><button>Salir</button></form>
  </header>
  <nav>
    <a href="/">Chats</a>
    <a href="/pendientes" class="active">Pendientes</a>
    <a href="/contactos">Contactos</a>
    <a href="/estadisticas">Estadísticas</a>
    <a href="/buscar">Buscar</a>
    <a href="/ocultos">Ocultos</a>
  </nav>

  <main>
    <div class="page-title">Chats sin respuesta</div>
    <div class="page-sub">Conversaciones donde el último mensaje fue del cliente y aún no recibieron respuesta, ordenadas por tiempo de espera.</div>

    <% if (chats.length === 0) { %>
      <div class="empty">
        <div class="icon">✅</div>
        Todos los chats tienen respuesta.<br>¡Buen trabajo!
      </div>
    <% } else { %>
      <% chats.forEach(function(chat) {
        const initial = (chat.phone_or_name || '?')[0].toUpperCase();
        const now     = Date.now();
        const diffMs  = now - (chat.waiting_since || chat.last_seen);
        const diffMin = Math.floor(diffMs / 60000);
        let waitLabel;
        if (diffMin < 60) waitLabel = diffMin + ' min';
        else if (diffMin < 1440) waitLabel = Math.floor(diffMin / 60) + ' h';
        else waitLabel = Math.floor(diffMin / 1440) + ' d';
        const urgent = diffMin > 30;
      %>
        <div class="pending-wrap" id="wrap-<%= chat.id %>">
          <a class="pending-card" href="/chat/<%= chat.id %>" style="<%= urgent ? '' : 'border-left-color:#ff7043;' %>; margin-bottom:0; padding-right: 100px;">
            <div class="avatar" style="<%= urgent ? '' : 'background:#ff7043;' %>"><%= initial %></div>
            <div class="card-info">
              <div class="card-name"><%= chat.phone_or_name %></div>
              <div class="card-msg">"<%= chat.last_message || '—' %>"</div>
            </div>
            <div class="card-meta">
              <div class="wait-time" style="<%= urgent ? '' : 'color:#ff7043;' %>"><%= waitLabel %></div>
              <div class="wait-label">esperando</div>
            </div>
          </a>
          <button class="resolver-btn" onclick="resolverChat(<%= chat.id %>)">✓ Resolver</button>
        </div>
      <% }); %>
    <% } %>
  </main>
  <script>
    function resolverChat(id) {
      fetch('/chat/' + id + '/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'resuelto' }),
      })
      .then(r => r.json())
      .then(d => {
        if (!d.ok) return;
        const wrap = document.getElementById('wrap-' + id);
        wrap.style.transition = 'opacity .25s';
        wrap.style.opacity = '0';
        setTimeout(() => wrap.remove(), 260);
      })
      .catch(() => {});
    }
    setInterval(() => location.reload(), 30000);
  </script>
</body>
</html>
