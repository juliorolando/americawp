<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= chat.phone_or_name %> — WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #efeae2;
      color: #111;
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    header {
      background: #25D366;
      color: #fff;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
      box-shadow: 0 1px 3px rgba(0,0,0,.15);
    }
    .back {
      color: #fff;
      text-decoration: none;
      font-size: 1.2rem;
      line-height: 1;
      padding: 4px;
    }
    .header-info { flex: 1; min-width: 0; }
    .header-name { font-weight: 600; font-size: .95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .header-sub  { font-size: .75rem; opacity: .85; margin-top: 1px; }
    .export-btn {
      background: rgba(255,255,255,.25);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 6px 12px;
      font-size: .8rem;
      cursor: pointer;
      text-decoration: none;
      white-space: nowrap;
    }
    .export-btn:hover { background: rgba(255,255,255,.38); }

    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 12px 8px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .day-separator {
      text-align: center;
      margin: 10px 0 6px;
    }
    .day-separator span {
      background: rgba(255,255,255,.75);
      color: #555;
      font-size: .72rem;
      padding: 3px 10px;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(0,0,0,.08);
    }

    .bubble-row {
      display: flex;
      max-width: 75%;
    }
    .bubble-row.out { align-self: flex-end; }
    .bubble-row.in  { align-self: flex-start; }

    .bubble {
      border-radius: 8px;
      padding: 7px 10px 4px;
      font-size: .88rem;
      line-height: 1.45;
      box-shadow: 0 1px 2px rgba(0,0,0,.1);
      word-break: break-word;
      position: relative;
    }
    .bubble-row.out .bubble {
      background: #d9fdd3;
      border-bottom-right-radius: 2px;
    }
    .bubble-row.in .bubble {
      background: #fff;
      border-bottom-left-radius: 2px;
    }

    .bubble-time {
      font-size: .68rem;
      color: #999;
      text-align: right;
      margin-top: 2px;
    }

    .empty { text-align: center; color: #888; margin: auto; font-size: .9rem; }

    @media (max-width: 480px) {
      .bubble-row { max-width: 88%; }
    }
  </style>
</head>
<body>
  <header>
    <a class="back" href="/" title="Volver">&#8592;</a>
    <div class="header-info">
      <div class="header-name"><%= chat.phone_or_name %></div>
      <div class="header-sub"><%= messages.length %> mensaje<%= messages.length !== 1 ? 's' : '' %></div>
    </div>
    <a class="export-btn" href="/export/<%= chat.id %>">Exportar .txt</a>
  </header>

  <div class="messages" id="msgs">
    <% if (messages.length === 0) { %>
      <p class="empty">No hay mensajes registrados en este chat.</p>
    <% } else {
      let lastDay = null;
      messages.forEach(function(msg) {
        const d = new Date(msg.timestamp);
        const dayKey = d.toDateString();
        const today  = new Date();
        let dayLabel;
        if (dayKey === today.toDateString()) dayLabel = 'Hoy';
        else {
          const yest = new Date(today); yest.setDate(today.getDate() - 1);
          if (dayKey === yest.toDateString()) dayLabel = 'Ayer';
          else dayLabel = d.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' });
        }
        const timeStr = d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit', hour12: false });
    %>
      <% if (dayKey !== lastDay) { lastDay = dayKey; %>
        <div class="day-separator"><span><%= dayLabel %></span></div>
      <% } %>

      <div class="bubble-row <%= msg.direction %>">
        <div class="bubble">
          <%= msg.body %>
          <div class="bubble-time"><%= timeStr %></div>
        </div>
      </div>
    <% }); } %>
  </div>

  <script>
    // Scroll al fondo al cargar
    const msgs = document.getElementById('msgs');
    msgs.scrollTop = msgs.scrollHeight;
  </script>
</body>
</html>
