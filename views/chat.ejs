<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= chat.phone_or_name %> — WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #efeae2;
      color: #111;
      display: flex;
      flex-direction: column;
      height: 100vh;
    }

    /* ── Header ── */
    header {
      background: #128C7E;
      color: #fff;
      padding: 11px 15px;
      display: flex;
      align-items: center;
      gap: 11px;
      flex-shrink: 0;
      box-shadow: 0 1px 4px rgba(0,0,0,.2);
    }
    .back {
      color: #fff;
      text-decoration: none;
      font-size: 1.2rem;
      padding: 4px;
      line-height: 1;
      opacity: .9;
    }
    .back:hover { opacity: 1; }
    .header-avatar {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: rgba(255,255,255,.25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .header-info { flex: 1; min-width: 0; }
    .header-name {
      font-weight: 600;
      font-size: .95rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .header-sub { font-size: .72rem; opacity: .8; margin-top: 2px; }

    .header-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .action-btn {
      background: rgba(255,255,255,.18);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 6px 11px;
      font-size: .78rem;
      cursor: pointer;
      text-decoration: none;
      white-space: nowrap;
    }
    .action-btn:hover { background: rgba(255,255,255,.3); }

    /* ── Messages ── */
    .messages {
      flex: 1;
      overflow-y: auto;
      padding: 14px 10px;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .day-separator {
      text-align: center;
      margin: 12px 0 8px;
    }
    .day-separator span {
      background: rgba(255,255,255,.82);
      color: #666;
      font-size: .71rem;
      padding: 3px 12px;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(0,0,0,.08);
    }

    .bubble-row {
      display: flex;
      max-width: 78%;
    }
    .bubble-row.out { align-self: flex-end; }
    .bubble-row.in  { align-self: flex-start; }

    .bubble {
      border-radius: 8px;
      padding: 7px 10px 4px;
      font-size: .875rem;
      line-height: 1.45;
      box-shadow: 0 1px 2px rgba(0,0,0,.1);
      word-break: break-word;
    }
    .bubble-row.out .bubble {
      background: #d9fdd3;
      border-bottom-right-radius: 2px;
    }
    .bubble-row.in .bubble {
      background: #fff;
      border-bottom-left-radius: 2px;
    }

    .bubble-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 4px;
      margin-top: 3px;
    }
    .bubble-time { font-size: .67rem; color: #aaa; }
    .bubble-row.out .bubble-time { color: #8cbe8c; }

    .empty { text-align: center; color: #888; margin: auto; font-size: .9rem; }

    /* ── Resp time badge ── */
    .resp-badge {
      background: rgba(255,255,255,.18);
      border-radius: 5px;
      padding: 3px 8px;
      font-size: .7rem;
      white-space: nowrap;
    }

    nav { background: #0f7268; display: flex; overflow-x: auto; scrollbar-width: none; flex-shrink: 0; }
    nav::-webkit-scrollbar { display: none; }
    nav a { color: rgba(255,255,255,.7); text-decoration: none; padding: 8px 16px; font-size: .8rem; font-weight: 500; white-space: nowrap; border-bottom: 2px solid transparent; }
    nav a:hover { color: #fff; }

    /* ── Status bar ── */
    .status-bar {
      background: #fff; border-bottom: 1px solid #ebebeb;
      padding: 7px 15px; display: flex; align-items: center; gap: 7px; flex-shrink: 0;
    }
    .status-label { font-size: .68rem; color: #bbb; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; margin-right: 2px; }
    .status-btn {
      padding: 4px 13px; border-radius: 20px; border: 1.5px solid #e0e0e0;
      background: #fff; font-size: .74rem; font-weight: 600; cursor: pointer;
      color: #bbb; transition: all .15s;
    }
    .status-btn.active.pendiente  { border-color: #90a4ae; background: #eceff1; color: #546e7a; }
    .status-btn.active.en_proceso { border-color: #ffb74d; background: #fff3e0; color: #e65100; }
    .status-btn.active.resuelto   { border-color: #66bb6a; background: #e8f5e9; color: #2e7d32; }

    /* ── Notes panel ── */
    .notes-panel { flex-shrink: 0; background: #fffde7; border-top: 1px solid #ffe082; }
    .notes-header {
      padding: 8px 15px; font-size: .78rem; font-weight: 600; color: #f57f17;
      cursor: pointer; display: flex; justify-content: space-between; align-items: center;
      user-select: none;
    }
    .notes-body { padding: 0 15px 12px; display: none; }
    .notes-body.open { display: block; }
    .notes-body textarea {
      width: 100%; min-height: 75px; border: 1px solid #ffe082; border-radius: 6px;
      padding: 8px 10px; font-size: .85rem; font-family: inherit;
      background: #fff; resize: vertical; outline: none; line-height: 1.45;
    }
    .notes-body textarea:focus { border-color: #f9a825; }
    .notes-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
    .notes-save { background: #f57f17; color: #fff; border: none; border-radius: 6px; padding: 5px 16px; font-size: .78rem; font-weight: 600; cursor: pointer; }
    .notes-save:hover { background: #e65100; }
    #notes-status { font-size: .72rem; color: #aaa; }

    @media (max-width: 480px) {
      .bubble-row { max-width: 88%; }
      .resp-badge { display: none; }
    }
  </style>
</head>
<body>
<%
  // Calcular tiempo de respuesta promedio
  let totalMs = 0, count = 0, lastInTs = null;
  messages.forEach(function(m) {
    if (m.direction === 'in') {
      lastInTs = m.timestamp;
    } else if (m.direction === 'out' && lastInTs !== null) {
      totalMs += m.timestamp - lastInTs;
      count++;
      lastInTs = null;
    }
  });
  const avgMin  = count > 0 ? Math.round(totalMs / count / 60000) : null;
  const avgLabel = avgMin === null ? null
                 : avgMin < 1    ? '< 1 min'
                 : avgMin < 60   ? avgMin + ' min'
                 : Math.round(avgMin / 60) + ' h';
  const initial = (chat.phone_or_name || '?')[0].toUpperCase();
%>
  <nav>
    <a href="/">Chats</a>
    <a href="/pendientes">Pendientes</a>
    <a href="/estadisticas">Estadísticas</a>
    <a href="/buscar">Buscar</a>
    <a href="/ocultos">Ocultos</a>
  </nav>
  <header>
    <a class="back" href="/" title="Volver">&#8592;</a>
    <div class="header-avatar"><%= initial %></div>
    <div class="header-info">
      <div class="header-name"><%= chat.phone_or_name %></div>
      <div class="header-sub"><%= messages.length %> mensaje<%= messages.length !== 1 ? 's' : '' %></div>
    </div>
    <div class="header-actions">
      <% if (avgLabel) { %>
        <span class="resp-badge">⏱ <%= avgLabel %> resp.</span>
      <% } %>
      <a class="action-btn" href="/export/<%= chat.id %>">Exportar .txt</a>
    </div>
  </header>

  <div class="status-bar">
    <span class="status-label">Estado</span>
    <button class="status-btn <%= chat.status === 'pendiente'  ? 'active pendiente'  : '' %>" data-status="pendiente"  onclick="cambiarEstado(this)">Pendiente</button>
    <button class="status-btn <%= chat.status === 'en_proceso' ? 'active en_proceso' : '' %>" data-status="en_proceso" onclick="cambiarEstado(this)">En proceso</button>
    <button class="status-btn <%= chat.status === 'resuelto'   ? 'active resuelto'   : '' %>" data-status="resuelto"   onclick="cambiarEstado(this)">Resuelto</button>
  </div>

  <div class="messages" id="msgs">
    <% if (messages.length === 0) { %>
      <p class="empty">No hay mensajes registrados en este chat.</p>
    <% } else {
      let lastDay = null;
      messages.forEach(function(msg) {
        const d      = new Date(msg.timestamp);
        const dayKey = d.toDateString();
        const today  = new Date();
        let dayLabel;
        if (dayKey === today.toDateString()) {
          dayLabel = 'Hoy';
        } else {
          const yest = new Date(today); yest.setDate(today.getDate() - 1);
          dayLabel = dayKey === yest.toDateString()
            ? 'Ayer'
            : d.toLocaleDateString('es-AR', { weekday: 'long', day: '2-digit', month: 'long' });
        }
        const timeStr = d.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit', hour12: false });
    %>
      <% if (dayKey !== lastDay) { lastDay = dayKey; %>
        <div class="day-separator"><span><%= dayLabel %></span></div>
      <% } %>

      <div class="bubble-row <%= msg.direction %>">
        <div class="bubble">
          <%= msg.body %>
          <div class="bubble-footer">
            <span class="bubble-time"><%= timeStr %></span>
            <% if (msg.direction === 'out') { %><span style="font-size:.7rem;color:#8cbe8c;">✓✓</span><% } %>
          </div>
        </div>
      </div>
    <% }); } %>
  </div>

  <div class="notes-panel">
    <div class="notes-header" onclick="toggleNotas()">
      <span>📝 Notas internas</span>
      <span id="notes-toggle"><%= chat.notes ? '▼' : '▲' %></span>
    </div>
    <div class="notes-body <%= chat.notes ? 'open' : '' %>" id="notes-body">
      <textarea id="notes-input" placeholder="Anotá contexto privado sobre este contacto (solo visible en el panel)…"><%= chat.notes %></textarea>
      <div class="notes-footer">
        <span id="notes-status"></span>
        <button class="notes-save" onclick="guardarNotas()">Guardar</button>
      </div>
    </div>
  </div>

  <script>
    const msgs = document.getElementById('msgs');
    msgs.scrollTop = 9999999;

    // Pausa el auto-refresh mientras el usuario escribe notas
    const notesInput = document.getElementById('notes-input');
    let notesActivo = false;
    notesInput.addEventListener('focus', () => notesActivo = true);
    notesInput.addEventListener('blur',  () => notesActivo = false);
    setInterval(() => { if (!notesActivo) location.reload(); }, 15000);

    function toggleNotas() {
      const body   = document.getElementById('notes-body');
      const toggle = document.getElementById('notes-toggle');
      body.classList.toggle('open');
      toggle.textContent = body.classList.contains('open') ? '▼' : '▲';
    }

    function guardarNotas() {
      const notes  = notesInput.value;
      const status = document.getElementById('notes-status');
      fetch('/chat/<%= chat.id %>/notes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes }),
      })
      .then(r => r.json())
      .then(d => {
        status.textContent = d.ok ? 'Guardado ✓' : 'Error';
        setTimeout(() => status.textContent = '', 2500);
      })
      .catch(() => { status.textContent = 'Error de red'; });
    }

    function cambiarEstado(btn) {
      const status = btn.dataset.status;
      fetch('/chat/<%= chat.id %>/status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      })
      .then(r => r.json())
      .then(d => {
        if (!d.ok) return;
        document.querySelectorAll('.status-btn').forEach(b =>
          b.classList.remove('active', 'pendiente', 'en_proceso', 'resuelto'));
        btn.classList.add('active', status);
      })
      .catch(() => {});
    }
  </script>
</body>
</html>
