<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ocultos — WasapPanel</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f2f5; color: #111; min-height: 100vh; }

    header { background: #128C7E; color: #fff; padding: 12px 18px; display: flex; align-items: center; gap: 10px; position: sticky; top: 0; z-index: 20; box-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .logo { font-size: 1.1rem; font-weight: 700; letter-spacing: -.3px; }
    .logo span { color: #a5d6a7; }
    header .spacer { flex: 1; }
    header form button { background: rgba(255,255,255,.15); border: none; color: #fff; font-size: .78rem; padding: 5px 12px; border-radius: 6px; cursor: pointer; }
    header form button:hover { background: rgba(255,255,255,.25); }

    nav { background: #0f7268; display: flex; overflow-x: auto; scrollbar-width: none; }
    nav::-webkit-scrollbar { display: none; }
    nav a { color: rgba(255,255,255,.7); text-decoration: none; padding: 10px 18px; font-size: .82rem; font-weight: 500; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .15s; }
    nav a:hover { color: #fff; }
    nav a.active { color: #fff; border-bottom-color: #25D366; }

    main { max-width: 700px; margin: 0 auto; padding: 20px 12px 40px; }

    .page-title { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
    .page-sub   { font-size: .82rem; color: #888; margin-bottom: 18px; }

    .hidden-card {
      background: #fff;
      border-radius: 10px;
      padding: 13px 16px;
      display: flex;
      align-items: center;
      gap: 13px;
      box-shadow: 0 1px 2px rgba(0,0,0,.07);
      margin-bottom: 7px;
      opacity: .75;
    }

    .avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: #b0bec5; color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; font-weight: 700; flex-shrink: 0;
    }

    .card-info { flex: 1; min-width: 0; }
    .card-name { font-weight: 600; font-size: .9rem; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-msg  { font-size: .78rem; color: #999; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .show-btn {
      background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7;
      border-radius: 6px; padding: 6px 14px; font-size: .78rem; font-weight: 600;
      cursor: pointer; white-space: nowrap; flex-shrink: 0;
    }
    .show-btn:hover { background: #c8e6c9; }

    .empty { text-align: center; color: #bbb; margin-top: 60px; font-size: .92rem; line-height: 1.7; }
    .empty .icon { font-size: 2.2rem; margin-bottom: 10px; }
  </style>
</head>
<body>
  <header>
    <div class="logo">Wasap<span>Panel</span></div>
    <div class="spacer"></div>
    <form method="POST" action="/logout"><button>Salir</button></form>
  </header>
  <nav>
    <a href="/">Chats</a>
    <a href="/pendientes">Pendientes</a>
    <a href="/contactos">Contactos</a>
    <a href="/estadisticas">Estadísticas</a>
    <a href="/buscar">Buscar</a>
    <% if (isAdmin) { %><a href="/ocultos" class="active">Ocultos</a><a href="/turnos">Turnos</a><% } %>
  </nav>

  <main>
    <div class="page-title">Conversaciones ocultas</div>
    <div class="page-sub">Estas conversaciones no aparecen en la lista principal. Podés restaurarlas en cualquier momento.</div>

    <% if (chats.length === 0) { %>
      <div class="empty">
        <div class="icon">👁</div>
        No hay conversaciones ocultas.
      </div>
    <% } else { %>
      <% chats.forEach(function(chat) {
        const initial = (chat.phone_or_name || '?')[0].toUpperCase();
      %>
        <div class="hidden-card">
          <div class="avatar"><%= initial %></div>
          <div class="card-info">
            <div class="card-name"><%= chat.phone_or_name %></div>
            <div class="card-msg"><%= chat.last_message || '—' %></div>
          </div>
          <form method="POST" action="/chat/<%= chat.id %>/show">
            <button type="submit" class="show-btn">Mostrar</button>
          </form>
        </div>
      <% }); %>
    <% } %>
  </main>
</body>
</html>
