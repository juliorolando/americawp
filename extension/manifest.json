{
  "manifest_version": 3,
  "name": "WasapPanel Monitor",
  "version": "1.0.0",
  "description": "Registra mensajes de WhatsApp Web en el panel de supervisión local",
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://panel.hosteriaamerica.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "WasapPanel Monitor"
  }
}
